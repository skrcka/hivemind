{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability: all praetor custom commands + the dialog plugin. All windows see this.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-start-dragging"
  ]
}
